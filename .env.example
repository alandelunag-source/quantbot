# Alpaca paper trading (get at https://alpaca.markets → Paper Trading → API Keys)
ALPACA_API_KEY=your_key_here
ALPACA_SECRET_KEY=your_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Optional: yfinance doesn't require a key
# Optional: override defaults
INITIAL_CAPITAL=100000
MAX_POSITION_PCT=0.05      # 5% max per stock
MAX_STRATEGY_PCT=0.20      # 20% max per strategy
DRAWDOWN_STOP_PCT=0.12     # halt if down 12% from peak
TRANSACTION_COST_BPS=3     # 3 bps per trade (realistic for US equities)
SLIPPAGE_BPS=1             # 1 bps slippage estimate
